{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "noUnusedLocals": true,
    "noImplicitOverride": true,
    "plugins": [
      {
        "name": "@effect/language-service",
        "ignoreEffectSuggestionsInTscExitCode": true,
        "ignoreEffectWarningsInTscExitCode": true,
        "diagnosticSeverity": {
          "preferSchemaOverJson": "off"
        }
      }
    ]
  },
  "include": ["src/sdk/**/*.ts"]
}
