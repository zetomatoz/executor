{
  "name": "@executor-js/plugin-azure-key-vault",
  "version": "0.0.0",
  "homepage": "https://github.com/RhysSullivan/executor/tree/main/packages/plugins/azure-key-vault",
  "bugs": {
    "url": "https://github.com/RhysSullivan/executor/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RhysSullivan/executor.git",
    "directory": "packages/plugins/azure-key-vault"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/sdk/index.ts",
    "./testing": "./src/sdk/testing.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./testing": {
        "import": {
          "types": "./dist/testing.d.ts",
          "default": "./dist/testing.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup && (tsc --declaration --emitDeclarationOnly --outDir dist --rootDir src || true)",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:slow": "bunx tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.11.2",
    "@executor-js/sdk": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "testcontainers": "^11.14.0",
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
}
